# =============================================
# bloom focus — Environment Variables
# Скопіюй цей файл як .env.local для локальної розробки
# Додай ці змінні в Vercel Settings → Environment Variables
# =============================================

# Supabase (bloomfocus project)
NEXT_PUBLIC_SUPABASE_URL=https://iqzwviqsqmstafxarkuw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Monobank (той самий токен що для TouchMemories)
MONO_TOKEN=your_mono_merchant_token_here
MONO_PUBLIC_KEY=your_mono_public_key_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://bloomfocus.org

# Brevo (для email після оплати)
BREVO_API_KEY=your_brevo_api_key_here
